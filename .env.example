# Jobber OAuth2 credentials (from https://developer.getjobber.com)
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=

# OAuth tokens — obtained after a company completes the OAuth flow.
# For FirstVisitAI integration, these are stored in the DB per-company.
# For standalone use, paste them here after completing the auth flow.
JOBBER_ACCESS_TOKEN=
JOBBER_REFRESH_TOKEN=

# Transport: "stdio" (default, for Claude Code) or "http" (for remote/hosted)
TRANSPORT=stdio

# HTTP transport settings (only used when TRANSPORT=http)
HTTP_PORT=3000
HTTP_HOST=localhost
