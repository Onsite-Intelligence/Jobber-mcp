{
  "name": "@onsite-intelligence/jobber-mcp",
  "version": "1.0.0",
  "description": "MCP server for the Jobber field service management API — client management, job scheduling, quoting, invoicing, and service request intake",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "jobber-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "scripts/",
    ".env.example",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "start:http": "TRANSPORT=http node dist/index.js",
    "dev:http": "TRANSPORT=http tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "jobber",
    "field-service",
    "home-services",
    "hvac",
    "plumbing",
    "ai-agent",
    "claude",
    "model-context-protocol"
  ],
  "author": "Onsite Intelligence Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Onsite-Intelligence/Jobber-mcp.git"
  },
  "homepage": "https://github.com/Onsite-Intelligence/Jobber-mcp",
  "bugs": {
    "url": "https://github.com/Onsite-Intelligence/Jobber-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^5.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
